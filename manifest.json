{
  "manifest_version": 3,
  "name": "LinkedIn Job Auto-Filter",
  "version": "1.0",
  "description": "Evaluates LinkedIn job descriptions against your resume using the Gemini API.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.google.com/",
    "https://*.googleusercontent.com/",
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "skills.md",
        "profile.md",
        "resume.md"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}